# Backend API
NEXT_PUBLIC_BACKEND_API=http://localhost:8000/api

# Ethereum/EVM Smart Contract
NEXT_PUBLIC_CONTRACT_ADDRESS=your_contract_address_here
NEXT_PUBLIC_CHAIN_ID=11155111

# Alchemy (for Coinbase Wallet & RPC)
NEXT_PUBLIC_ALCHEMY_KEY=your_alchemy_key_here

# WalletConnect Project ID (Get from https://cloud.walletconnect.com)
NEXT_PUBLIC_WALLETCONNECT_PROJECT_ID=your_walletconnect_project_id

# Algorand Configuration
NEXT_PUBLIC_ALGORAND_NODE=https://testnet-api.algonode.cloud
NEXT_PUBLIC_ALGORAND_INDEXER=https://testnet-idx.algonode.cloud

# Solana Configuration
NEXT_PUBLIC_SOLANA_RPC=https://api.devnet.solana.com

# Coinbase SDK (Server-side only - DO NOT expose in frontend)
NEXT_PUBLIC_COINBASE_API_KEY=your_coinbase_api_key
NEXT_PUBLIC_COINBASE_API_SECRET=your_coinbase_api_secret

# x402 Payment Automation
NEXT_PUBLIC_X402_API_URL=https://api.x402.io
NEXT_PUBLIC_X402_API_KEY=your_x402_api_key

# Firebase Configuration
NEXT_PUBLIC_FIREBASE_API_KEY=your_firebase_api_key
NEXT_PUBLIC_FIREBASE_AUTH_DOMAIN=your_project_id.firebaseapp.com
NEXT_PUBLIC_FIREBASE_PROJECT_ID=your_project_id
NEXT_PUBLIC_FIREBASE_STORAGE_BUCKET=your_project_id.firebasestorage.app
NEXT_PUBLIC_FIREBASE_MESSAGING_SENDER_ID=your_messaging_sender_id
NEXT_PUBLIC_FIREBASE_APP_ID=your_app_id
NEXT_PUBLIC_FIREBASE_MEASUREMENT_ID=your_measurement_id
